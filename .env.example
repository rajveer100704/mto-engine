# ============================================================
# Environment Variables — copy to .env before running
# ============================================================

# --- AI Provider ---
# Leave empty → Mock mode (always works, no API key needed)
# Get a free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Optional: Force mock mode even with a valid key
# AI_PROVIDER=mock

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
